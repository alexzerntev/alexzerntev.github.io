---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Alex Zerntev`} description={description}>
  <article class="flex-1 px-6 py-16 md:py-24 max-w-2xl mx-auto w-full">
    <header class="mb-12">
      <a
        href="/blog"
        class="text-xs tracking-widest uppercase text-slate-500 hover:text-slate-300 transition-colors duration-300"
      >
        &larr; Back
      </a>
      <h1 class="font-display text-4xl md:text-5xl text-slate-100 mt-6 leading-tight">
        {title}
      </h1>
      <time
        datetime={date.toISOString()}
        class="mt-4 block text-sm text-slate-500 tracking-wide"
      >
        {formattedDate}
      </time>
    </header>

    <div class="prose prose-invert prose-lg max-w-none
      [&_p]:text-slate-400 [&_p]:leading-relaxed
      [&_a]:text-slate-100 [&_a]:underline [&_a]:decoration-slate-600
      [&_a:hover]:decoration-slate-100 [&_a]:transition-colors
      [&_h2]:font-display [&_h2]:text-slate-100 [&_h2]:mt-12 [&_h2]:mb-4
      [&_h3]:font-display [&_h3]:text-slate-100
      [&_blockquote]:border-slate-700 [&_blockquote]:text-slate-400 [&_blockquote]:font-display [&_blockquote]:italic
      [&_code]:text-sm [&_code]:bg-slate-800 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded
      [&_pre]:bg-slate-900 [&_pre]:text-slate-100
    ">
      <slot />
    </div>
  </article>
</BaseLayout>
