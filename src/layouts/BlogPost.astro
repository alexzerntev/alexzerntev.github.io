---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Alex Zerntev`} description={description}>
  <article class="flex-1 px-6 py-16 md:py-24 max-w-2xl mx-auto w-full">
    <header class="mb-12">
      <a
        href="/blog"
        class="text-xs tracking-widest uppercase text-stone-400 hover:text-stone-600 transition-colors duration-300"
      >
        &larr; Back
      </a>
      <h1 class="font-serif text-4xl md:text-5xl text-stone-900 mt-6 leading-tight">
        {title}
      </h1>
      <time
        datetime={date.toISOString()}
        class="mt-4 block text-sm text-stone-400 tracking-wide"
      >
        {formattedDate}
      </time>
    </header>

    <div class="prose prose-stone prose-lg max-w-none
      [&_p]:text-stone-600 [&_p]:leading-relaxed
      [&_a]:text-stone-900 [&_a]:underline [&_a]:decoration-stone-300
      [&_a:hover]:decoration-stone-900 [&_a]:transition-colors
      [&_h2]:font-serif [&_h2]:text-stone-900 [&_h2]:mt-12 [&_h2]:mb-4
      [&_h3]:font-serif [&_h3]:text-stone-900
      [&_blockquote]:border-stone-200 [&_blockquote]:text-stone-500 [&_blockquote]:font-serif [&_blockquote]:italic
      [&_code]:text-sm [&_code]:bg-stone-100 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded
      [&_pre]:bg-stone-900 [&_pre]:text-stone-100
    ">
      <slot />
    </div>
  </article>
</BaseLayout>
