---
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { 
  title, 
  description = 'Alex Zerntev — AI Engineer & Full Stack Engineer. Building production AI systems and scalable platforms. MSc in Data Science & AI.',
  ogImage = '/alex.png'
} = Astro.props;
const fullTitle = title === 'Alex Zerntev' ? 'Alex Zerntev — AI Engineer & Full Stack Engineer' : `${title} | Alex Zerntev`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Alex Zerntev" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="Alex Zerntev" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@alexzerntev" />
    <meta name="twitter:creator" content="@alexzerntev" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    
    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alex Zerntev",
      "url": "https://alexzerntev.github.io",
      "jobTitle": "AI Engineer & Full Stack Engineer",
      "worksFor": {
        "@type": "Organization",
        "name": "RAW Labs"
      },
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "National and Kapodistrian University of Athens"
      },
      "sameAs": [
        "https://github.com/alexzerntev",
        "https://linkedin.com/in/alexzerntev",
        "https://x.com/alexzerntev",
        "https://medium.com/@alexzerntev"
      ],
      "knowsAbout": ["AI Engineering", "Full Stack Development", "Data Infrastructure", "Machine Learning", "AI Agents"]
    })} />
  </head>
  <body class="bg-[var(--color-surface-0)] text-[var(--color-text-primary)] font-sans min-h-screen flex flex-col antialiased relative overflow-x-hidden">
    <!-- Noise texture -->
    <div class="noise-overlay" aria-hidden="true"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-40 animate-fade-in delay-8">
      <div class="max-w-6xl mx-auto px-6 md:px-10 py-5 flex items-center justify-between">
        <a href="/" class="text-sm tracking-widest uppercase text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] transition-colors duration-300">
          AZ
        </a>
        <div class="flex items-center gap-6">
          <a
            href="/blog"
            class="text-xs tracking-widest uppercase text-[var(--color-text-muted)] hover:text-[var(--color-text-tertiary)] transition-colors duration-300"
          >
            Blog
            <span class="ml-1.5 text-[10px] text-[var(--color-accent-dim)] border border-[var(--color-accent-dim)] rounded px-1 py-px align-middle">Soon</span>
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Scroll reveal script -->
    <script>
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      reveals.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
