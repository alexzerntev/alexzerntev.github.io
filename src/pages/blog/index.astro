---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Writing — Alex Zerntev">
  <main class="flex-1 px-6 py-16 md:py-24 max-w-2xl mx-auto w-full">
    <header class="mb-12 md:mb-16">
      <a
        href="/"
        class="text-xs tracking-widest uppercase text-slate-500 hover:text-slate-300 transition-colors duration-300"
      >
        &larr; Home
      </a>
      <h1 class="font-display text-4xl md:text-5xl text-slate-100 mt-6">
        Writing
      </h1>
      <div class="mt-4 h-px w-16 bg-slate-700" aria-hidden="true"></div>
    </header>

    {posts.length === 0 ? (
      <p class="text-slate-500 text-lg">Nothing here yet.</p>
    ) : (
      <ul class="space-y-8">
        {posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}`}
              class="group block"
            >
              <time
                datetime={post.data.date.toISOString()}
                class="text-xs tracking-widest uppercase text-slate-500"
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                })}
              </time>
              <h2 class="font-display text-2xl text-slate-100 mt-1 group-hover:text-slate-400 transition-colors duration-300">
                {post.data.title}
              </h2>
              <p class="text-slate-400 mt-2 leading-relaxed">
                {post.data.description}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>
