---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Alex Zerntev">
  <main class="flex-1 relative">

    <!-- ═══ Ambient background orbs ═══ -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="gradient-orb w-[500px] h-[500px] bg-[var(--color-accent)] opacity-[0.03] top-[-10%] right-[-10%] animate-float"></div>
      <div class="gradient-orb w-[400px] h-[400px] bg-[var(--color-accent-bright)] opacity-[0.02] bottom-[20%] left-[-8%] animate-float" style="animation-delay: -3s;"></div>
    </div>

    <!-- ═══ Decorative geometry ═══ -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="geo-ring w-[300px] h-[300px] md:w-[500px] md:h-[500px] top-[-80px] right-[-100px] md:right-[-60px] opacity-40 animate-rotate-slow"></div>
      <div class="geo-ring w-[120px] h-[120px] top-[60%] left-[-40px] opacity-30" style="animation: rotate-slow 20s linear infinite reverse;"></div>
      <div class="geo-cross w-5 h-5 top-[30%] right-[15%] opacity-30 hidden md:block"></div>
      <div class="geo-cross w-3 h-3 top-[75%] left-[20%] opacity-20 hidden md:block"></div>
    </div>

    <!-- ═══ HERO SECTION ═══ -->
    <section class="min-h-screen flex items-center relative px-6 md:px-10 pt-24 pb-16">
      <div class="max-w-6xl mx-auto w-full">
        <div class="grid md:grid-cols-12 gap-10 md:gap-16 items-start">

          <!-- Text column -->
          <div class="md:col-span-7 order-2 md:order-1">
            <!-- Overline -->
            <p class="text-xs tracking-[0.3em] uppercase text-[var(--color-accent-dim)] mb-6 animate-fade-up delay-1">
              AI Engineer &bull; Full Stack Engineer
            </p>

            <!-- Name — oversized serif -->
            <h1 class="animate-fade-up delay-2">
              <span class="block font-serif text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight text-[var(--color-text-primary)] leading-[0.9]">
                Alex
              </span>
              <span class="block font-serif text-6xl sm:text-7xl md:text-8xl lg:text-9xl tracking-tight text-[var(--color-text-primary)] leading-[0.9] mt-1">
                Zerntev
              </span>
            </h1>

            <!-- Accent line -->
            <div class="h-px w-24 bg-gradient-to-r from-[var(--color-accent)] to-transparent mt-8 animate-draw-line delay-3" aria-hidden="true"></div>

            <!-- Intro copy -->
            <p class="text-lg md:text-xl leading-relaxed text-[var(--color-text-secondary)] max-w-lg mt-8 animate-fade-up delay-4">
              I engineer production AI systems and scalable platforms. From published research in robotics to enterprise infrastructure serving 10,000+ users — I architect intelligent systems that solve real problems.
            </p>

            <!-- Credentials bar -->
            <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-6 animate-fade-up delay-5">
              <span class="text-xs tracking-wider text-[var(--color-text-muted)]">MSc Data Science & AI</span>
              <span class="text-[var(--color-accent-dim)] text-xs">&bull;</span>
              <span class="text-xs tracking-wider text-[var(--color-text-muted)]">10+ Years in Engineering</span>
              <span class="text-[var(--color-accent-dim)] text-xs">&bull;</span>
              <span class="text-xs tracking-wider text-[var(--color-text-muted)]">Building at RAW Labs</span>
            </div>

            <!-- Social links — horizontal -->
            <div class="flex items-center gap-5 mt-8 animate-fade-up delay-6">
              <a href="https://github.com/alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="GitHub">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
              <a href="https://linkedin.com/in/alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="LinkedIn">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href="https://x.com/alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="X">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://medium.com/@alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="Medium">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
              </a>
              <a href="mailto:alexzerntev@gmail.com" class="social-icon text-[var(--color-text-muted)]" aria-label="Email">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Photo column -->
          <div class="md:col-span-5 order-1 md:order-2 flex justify-center md:justify-end animate-fade-in delay-2" style="align-self: start; margin-top: -5rem;">
            <div class="hero-photo-container w-full max-w-[320px] md:max-w-[400px]">
              <img src="/alex.png" alt="Alex Zerntev" class="hero-photo" loading="eager" />
            </div>
          </div>

        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-fade-in delay-8 hidden md:block">
          <div class="flex flex-col items-center gap-2 text-[var(--color-text-muted)]">
            <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
            <div class="w-px h-8 bg-gradient-to-b from-[var(--color-text-muted)] to-transparent"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ DIVIDER ═══ -->
    <div class="section-divider max-w-6xl mx-auto" aria-hidden="true"></div>

    <!-- ═══ EXPERTISE SECTION ═══ -->
    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="max-w-6xl mx-auto">
        <!-- Section label -->
        <div class="reveal">
          <p class="text-xs tracking-[0.3em] uppercase text-[var(--color-accent-dim)] mb-12 md:mb-16">Expertise</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 md:gap-8">
          <!-- Card 1 — AI Engineering -->
          <div class="card-surface rounded-xl p-7 md:p-8 reveal" style="transition-delay: 0.1s;">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-surface-3)] flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4c0 2 1 3.5 2 4.5L12 12l2-1.5c1-1 2-2.5 2-4.5a4 4 0 0 0-4-4z"/><path d="M12 12v10"/><path d="M8 22h8"/><circle cx="12" cy="6" r="1"/></svg>
            </div>
            <h3 class="font-serif text-xl text-[var(--color-text-primary)] mb-3">AI Engineering</h3>
            <p class="text-sm leading-relaxed text-[var(--color-text-tertiary)]">
              Architecting production AI systems — from intelligent agents and retrieval pipelines to real-time inference at scale. Published researcher in robotics and SLAM at IEEE IROS 2019.
            </p>
          </div>

          <!-- Card 2 — Systems Architecture -->
          <div class="card-surface rounded-xl p-7 md:p-8 reveal" style="transition-delay: 0.2s;">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-surface-3)] flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3 class="font-serif text-xl text-[var(--color-text-primary)] mb-3">Software Development</h3>
            <p class="text-sm leading-relaxed text-[var(--color-text-tertiary)]">
              Full-stack engineering across the entire stack — from enterprise platforms serving 10,000+ users to developer tooling, APIs, and query language compilers. Shipping reliable software that scales.
            </p>
          </div>

          <!-- Card 3 — Data Infrastructure -->
          <div class="card-surface rounded-xl p-7 md:p-8 reveal" style="transition-delay: 0.3s;">
            <div class="w-10 h-10 rounded-lg bg-[var(--color-surface-3)] flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            </div>
            <h3 class="font-serif text-xl text-[var(--color-text-primary)] mb-3">Data Infrastructure</h3>
            <p class="text-sm leading-relaxed text-[var(--color-text-tertiary)]">
              The connective layer between raw data and intelligence. Query engines, ETL pipelines, and the foundational infrastructure that powers modern AI applications.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ DIVIDER ═══ -->
    <div class="section-divider max-w-6xl mx-auto" aria-hidden="true"></div>

    <!-- ═══ CURRENT FOCUS SECTION ═══ -->
    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-12 gap-12 md:gap-16">
          <!-- Left — label -->
          <div class="md:col-span-4 reveal">
            <p class="text-xs tracking-[0.3em] uppercase text-[var(--color-accent-dim)] mb-4">Current Focus</p>
            <h2 class="font-serif text-3xl md:text-4xl text-[var(--color-text-primary)] leading-tight">
              Where I'm pushing<br />forward
            </h2>
          </div>

          <!-- Right — content -->
          <div class="md:col-span-8 reveal" style="transition-delay: 0.15s;">
            <div class="space-y-8">
              <div class="flex gap-5 items-start group">
                <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2.5 shrink-0 group-hover:scale-150 transition-transform"></div>
                <div>
                  <h3 class="text-[var(--color-text-primary)] font-medium mb-1">Agentic AI Systems</h3>
                  <p class="text-sm text-[var(--color-text-tertiary)] leading-relaxed">Architecting autonomous agent systems with robust tool use, orchestration, and the Model Context Protocol. Moving AI agents from prototypes to production-grade infrastructure.</p>
                </div>
              </div>
              <div class="flex gap-5 items-start group">
                <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2.5 shrink-0 group-hover:scale-150 transition-transform"></div>
                <div>
                  <h3 class="text-[var(--color-text-primary)] font-medium mb-1">AI-Native Development</h3>
                  <p class="text-sm text-[var(--color-text-tertiary)] leading-relaxed">Redefining software engineering with AI as a first-class collaborator — beyond code generation to fundamentally new workflows that amplify engineering expertise.</p>
                </div>
              </div>
              <div class="flex gap-5 items-start group">
                <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2.5 shrink-0 group-hover:scale-150 transition-transform"></div>
                <div>
                  <h3 class="text-[var(--color-text-primary)] font-medium mb-1">Data-to-AI Infrastructure</h3>
                  <p class="text-sm text-[var(--color-text-tertiary)] leading-relaxed">Building the foundational layer at RAW Labs that connects raw data sources directly to AI systems, eliminating traditional bottlenecks in the data-to-intelligence pipeline.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ DIVIDER ═══ -->
    <div class="section-divider max-w-6xl mx-auto" aria-hidden="true"></div>

    <!-- ═══ QUOTE SECTION ═══ -->
    <section class="px-6 md:px-10 py-24 md:py-32">
      <div class="max-w-6xl mx-auto">
        <div class="reveal max-w-3xl mx-auto text-center">
          <!-- Decorative quote mark -->
          <div class="mb-8">
            <span class="font-serif text-7xl md:text-8xl text-[var(--color-accent)] opacity-20 leading-none select-none" aria-hidden="true">&ldquo;</span>
          </div>

          <blockquote>
            <p class="font-serif text-2xl md:text-3xl lg:text-4xl text-[var(--color-text-secondary)] leading-snug tracking-tight">
              If you always put limit on everything you do, physical or anything
              else, it will spread into your work and into your life. There are
              no limits. There are only plateaus, and you must not stay there,
              you must go beyond them.
            </p>
          </blockquote>

          <!-- Attribution -->
          <div class="mt-8 flex items-center justify-center gap-3">
            <div class="h-px w-8 bg-[var(--color-accent-dim)]" aria-hidden="true"></div>
            <cite class="text-xs tracking-[0.25em] uppercase text-[var(--color-accent-dim)] not-italic">
              Bruce Lee
            </cite>
            <div class="h-px w-8 bg-[var(--color-accent-dim)]" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="px-6 md:px-10 py-12 border-t border-[var(--color-border)]">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <p class="text-xs text-[var(--color-text-muted)] tracking-wider">
          &copy; {new Date().getFullYear()} Alex Zerntev
        </p>
        <div class="flex items-center gap-5">
          <a href="https://github.com/alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="GitHub">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/in/alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="LinkedIn">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://x.com/alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="X">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://medium.com/@alexzerntev" target="_blank" rel="noopener noreferrer" class="social-icon text-[var(--color-text-muted)]" aria-label="Medium">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
          </a>
          <a href="mailto:alexzerntev@gmail.com" class="social-icon text-[var(--color-text-muted)]" aria-label="Email">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
        </div>
      </div>
    </footer>

  </main>
</BaseLayout>
