---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GraduationCapIcon, ClockIcon, RocketIcon, GithubIcon, LinkedinIcon, XTwitterIcon, MediumIcon, EnvelopeIcon, BrainIcon, CodeIcon, DatabaseIcon } from '../components/Icons';
---

<BaseLayout title="Alex Zerntev">
  <!-- Hero Section -->
  <main>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-16 sm:pb-32">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-7 space-y-6 sm:space-y-8 order-2 lg:order-1">
          <div class="space-y-6">
            <span class="text-primary font-bold uppercase tracking-[0.3em] text-xs">AI Engineer &middot; Full Stack Engineer</span>
            <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter leading-[0.9] text-slate-100 mt-4">
              Alex<br />Zerntev
            </h1>
          </div>
          <p class="text-lg sm:text-xl lg:text-2xl text-slate-400 leading-relaxed font-light max-w-2xl">
            I engineer production AI systems and scalable platforms. From published research in robotics to enterprise-grade infrastructure - I architect intelligent systems that solve real problems.
          </p>
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 text-sm text-slate-500 font-medium">
            <span class="flex items-center gap-2"><GraduationCapIcon className="w-4 h-4 text-primary" client:load /> MSc Data Science &amp; AI</span>
            <span class="hidden sm:inline text-zinc-700">&bull;</span>
            <span class="flex items-center gap-2"><ClockIcon className="w-4 h-4 text-primary" client:load /> 10+ Years in Engineering</span>
            <span class="hidden sm:inline text-zinc-700">&bull;</span>
            <span class="flex items-center gap-2"><RocketIcon className="w-4 h-4 text-primary" client:load /> Building at <a href="https://raw-labs.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">RAW Labs</a></span>
          </div>
          <!-- Social Icons Row -->
          <div class="flex flex-wrap items-center gap-3 sm:gap-4 md:gap-6 pt-4">
            <a class="group flex flex-col items-center gap-2" href="https://github.com/alexzerntev" target="_blank" rel="noopener noreferrer">
              <div class="size-10 sm:size-12 rounded-full border border-zinc-border flex items-center justify-center group-hover:border-primary group-hover:bg-primary/10 transition-all">
                <GithubIcon className="w-5 h-5 text-slate-400 group-hover:text-primary" client:load />
              </div>
              <span class="text-[10px] uppercase tracking-widest text-slate-600 group-hover:text-slate-300 transition-colors">GitHub</span>
            </a>
            <a class="group flex flex-col items-center gap-2" href="https://linkedin.com/in/alexzerntev" target="_blank" rel="noopener noreferrer">
              <div class="size-10 sm:size-12 rounded-full border border-zinc-border flex items-center justify-center group-hover:border-primary group-hover:bg-primary/10 transition-all">
                <LinkedinIcon className="w-5 h-5 text-slate-400 group-hover:text-primary" client:load />
              </div>
              <span class="text-[10px] uppercase tracking-widest text-slate-600 group-hover:text-slate-300 transition-colors">LinkedIn</span>
            </a>
            <a class="group flex flex-col items-center gap-2" href="https://x.com/alexzerntev" target="_blank" rel="noopener noreferrer">
              <div class="size-10 sm:size-12 rounded-full border border-zinc-border flex items-center justify-center group-hover:border-primary group-hover:bg-primary/10 transition-all">
                <XTwitterIcon className="w-5 h-5 text-slate-400 group-hover:text-primary" client:load />
              </div>
              <span class="text-[10px] uppercase tracking-widest text-slate-600 group-hover:text-slate-300 transition-colors">X</span>
            </a>
            <a class="group flex flex-col items-center gap-2" href="https://medium.com/@alexzerntev" target="_blank" rel="noopener noreferrer">
              <div class="size-10 sm:size-12 rounded-full border border-zinc-border flex items-center justify-center group-hover:border-primary group-hover:bg-primary/10 transition-all">
                <MediumIcon className="w-5 h-5 text-slate-400 group-hover:text-primary" client:load />
              </div>
              <span class="text-[10px] uppercase tracking-widest text-slate-600 group-hover:text-slate-300 transition-colors">Medium</span>
            </a>
            <a class="group flex flex-col items-center gap-2" href="mailto:alexzerntev@gmail.com">
              <div class="size-10 sm:size-12 rounded-full border border-zinc-border flex items-center justify-center group-hover:border-primary group-hover:bg-primary/10 transition-all">
                <EnvelopeIcon className="w-5 h-5 text-slate-400 group-hover:text-primary" client:load />
              </div>
              <span class="text-[10px] uppercase tracking-widest text-slate-600 group-hover:text-slate-300 transition-colors">Email</span>
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative group order-1 lg:order-2">
          <div class="absolute -inset-4 bg-primary/20 blur-3xl rounded-full opacity-20 group-hover:opacity-40 transition-opacity"></div>
          <div class="relative w-full aspect-[4/5] rounded-2xl overflow-hidden border border-zinc-border shadow-2xl">
            <img class="w-full h-full object-cover grayscale contrast-125" src="/alex.png" alt="Alex Zerntev" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-background-dark via-transparent to-transparent"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Expertise Section -->
    <section class="scroll-mt-20 py-16 sm:py-24 border-y border-zinc-border bg-black/40" id="expertise">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
          <div class="space-y-4">
            <h2 class="text-4xl font-bold tracking-tight">Expertise</h2>
          </div>
          <div class="hidden md:block h-[1px] flex-1 bg-zinc-border mx-12 mb-4"></div>
          <span class="text-slate-600 font-mono text-sm md:mb-2">01 / CORE SKILLS</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-8">
          <!-- AI Engineering -->
          <div class="p-8 sm:p-10 rounded-xl border border-zinc-border bg-zinc-950 hover:bg-zinc-900/50 transition-all group">
            <div class="mb-8">
              <BrainIcon className="w-9 h-9 text-primary group-hover:scale-110 transition-transform" client:load />
            </div>
            <h3 class="text-xl font-bold mb-4">AI Engineering</h3>
            <p class="text-slate-400 leading-relaxed">Architecting production AI systems - from intelligent agents and retrieval pipelines to real-time inference at scale. Published researcher in robotics and SLAM at IEEE IROS 2019.</p>
          </div>
          <!-- Software Development -->
          <div class="p-8 sm:p-10 rounded-xl border border-zinc-border bg-zinc-950 hover:bg-zinc-900/50 transition-all group">
            <div class="mb-8">
              <CodeIcon className="w-9 h-9 text-primary group-hover:scale-110 transition-transform" client:load />
            </div>
            <h3 class="text-xl font-bold mb-4">Software Development</h3>
            <p class="text-slate-400 leading-relaxed">Full-stack engineering across the entire stack - from enterprise platforms to developer tooling, APIs, and query language compilers. Shipping reliable software that scales.</p>
          </div>
          <!-- Data Infrastructure -->
          <div class="p-8 sm:p-10 rounded-xl border border-zinc-border bg-zinc-950 hover:bg-zinc-900/50 transition-all group">
            <div class="mb-8">
              <DatabaseIcon className="w-9 h-9 text-primary group-hover:scale-110 transition-transform" client:load />
            </div>
            <h3 class="text-xl font-bold mb-4">Data Infrastructure</h3>
            <p class="text-slate-400 leading-relaxed">The connective layer between raw data and intelligence. Query engines, ETL pipelines, and the foundational infrastructure that powers modern AI applications.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Current Focus Section -->
    <section class="scroll-mt-20 py-16 sm:py-24 lg:py-32" id="focus">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
          <div class="lg:col-span-4 space-y-6">
            <h2 class="text-4xl font-bold tracking-tight">Current Focus</h2>
          </div>
          <div class="lg:col-span-8 space-y-4">
            <!-- Item 1 -->
            <div class="glass-card p-6 sm:p-8 rounded-2xl flex items-start gap-6 sm:gap-8 hover:bg-white/[0.05] transition-colors group">
              <span class="font-mono text-primary text-2xl opacity-50">01</span>
              <div>
                <h4 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">Autonomous AI Agents</h4>
                <p class="text-slate-400">Designing agent systems that reason, use tools, and execute multi-step workflows autonomously - bridging the gap between language models and real-world task completion.</p>
              </div>
            </div>
            <!-- Item 2 -->
            <div class="glass-card p-6 sm:p-8 rounded-2xl flex items-start gap-6 sm:gap-8 hover:bg-white/[0.05] transition-colors group">
              <span class="font-mono text-primary text-2xl opacity-50">02</span>
              <div>
                <h4 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">The Data-to-AI Pipeline</h4>
                <p class="text-slate-400">Making enterprise data directly accessible to AI systems - declarative interfaces, context protocols, and infrastructure that eliminates the friction between raw data and intelligence.</p>
              </div>
            </div>
            <!-- Item 3 -->
            <div class="glass-card p-6 sm:p-8 rounded-2xl flex items-start gap-6 sm:gap-8 hover:bg-white/[0.05] transition-colors group">
              <span class="font-mono text-primary text-2xl opacity-50">03</span>
              <div>
                <h4 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">AI-Native Workflows</h4>
                <p class="text-slate-400">Rethinking how software gets built when AI is a first-class collaborator - not just code generation, but fundamentally new engineering processes that multiply what a single person can deliver.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quote Section -->
    <section class="scroll-mt-20 py-14 sm:py-20 md:py-28 bg-zinc-950 border-y border-zinc-border overflow-hidden relative" id="quote">
      <div class="absolute inset-0 opacity-10 flex items-center justify-center" aria-hidden="true">
        <span class="text-[5rem] sm:text-[8rem] md:text-[14rem] font-black pointer-events-none select-none">&ldquo;</span>
      </div>
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center relative z-10">
        <h2 class="text-xl sm:text-2xl md:text-3xl font-medium tracking-tight leading-relaxed text-white italic">
          &ldquo;If you always put limit on everything you do, physical or anything else, it will spread into your work and into your life. There are no limits. There are only plateaus, and you must not stay there, you must go beyond them.&rdquo;
        </h2>
        <p class="mt-12 font-mono text-primary tracking-widest uppercase text-sm">&mdash; Bruce Lee</p>
      </div>
    </section>
  </main>
</BaseLayout>
